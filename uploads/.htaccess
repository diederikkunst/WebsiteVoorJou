# Prevent execution of uploaded files
Options -ExecCGI
<FilesMatch "\.(php\d?|phtml|pl|py|jsp|asp|sh|cgi)$">
    Require all denied
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Deny all by default
Require all denied

# Allow access to static files only
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|pdf|doc|docx|xls|xlsx|zip|txt)$">
    Require all granted
</FilesMatch>
